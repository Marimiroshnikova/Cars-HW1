<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F1F1">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="104dp"
            android:layout_height="104dp"
            app:cardCornerRadius="52dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#F6F6F6">

            <TextView
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="✓"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/confirmation_inner_circle" />

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done!"
            android:textSize="46sp"
            android:textStyle="bold"
            android:textColor="#202020"
            android:layout_marginTop="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You card has been successfully charged"
            android:textSize="18sp"
            android:textColor="#202020"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnGoFirstPage"
            android:layout_width="220dp"
            android:layout_height="54dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/confirmation_button_bg"
            android:text="Go To First Page"
            android:textAllCaps="false"
            android:textColor="#2C2C2C"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>