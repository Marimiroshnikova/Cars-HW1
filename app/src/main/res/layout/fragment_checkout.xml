<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvPaymentTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#202020"
        android:layout_marginStart="20dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Contact Information -->
    <LinearLayout
        android:id="@+id/layoutContact"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_bg_f9"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvPaymentTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Information"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#202020"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+84932000000\namandamorgan@example.com"
            android:textSize="10sp"
            android:textColor="#000000"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Item header -->
    <RelativeLayout
        android:id="@+id/layoutItemHeader"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/layoutContact"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Item"
            android:textSize="21sp"
            android:textStyle="bold"
            android:textColor="#202020"/>

        <LinearLayout
            android:layout_width="121dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/discount_badge_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="5% Discount"
                android:textSize="12sp"
                android:textColor="#FFFFFF"/>

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#FFFFFF"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- Item row: circular image + name + prices -->
    <RelativeLayout
        android:id="@+id/layoutItemRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutItemHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Circular image -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCarThumb"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_alignParentStart="true"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <ImageView
                android:id="@+id/ivCarThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>

        <!-- Car name -->
        <TextView
            android:id="@+id/tvCarName"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/cardCarThumb"
            android:layout_marginStart="12dp"
            android:layout_centerVertical="true"
            android:textSize="12sp"
            android:textColor="#000000"
            android:maxLines="2"/>

        <!-- Discounted price -->
        <TextView
            android:id="@+id/tvDiscountedPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#202020"/>

        <!-- Original price (strikethrough) -->
        <TextView
            android:id="@+id/tvOriginalPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@id/tvDiscountedPrice"
            android:layout_alignParentEnd="true"
            android:textSize="11sp"
            android:textColor="#AAAAAA"/>

    </RelativeLayout>

    <!-- Shipping Options -->
    <LinearLayout
        android:id="@+id/layoutShipping"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/layoutItemRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shipping Options"
            android:textSize="21sp"
            android:textStyle="bold"
            android:textColor="#202020"
            android:layout_marginBottom="10dp"/>

        <!-- Standard -->
        <RelativeLayout
            android:id="@+id/layoutStandard"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/rounded_bg_e5ebfc"
            android:layout_marginBottom="6dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgRadioStandard"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_radio_off"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imgRadioStandard"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:text="Standard"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:text="FREE"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"/>
        </RelativeLayout>

        <!-- Express -->
        <RelativeLayout
            android:id="@+id/layoutExpress"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/rounded_bg_e5ebfc"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgRadioExpress"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_radio_off"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imgRadioExpress"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:text="Express"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:text="$1,700"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"/>
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delivered on or before Thursday, 23 April 2026"
            android:textSize="12sp"
            android:textColor="#000000"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Total + Pay -->
    <RelativeLayout
        android:id="@+id/layoutTotal"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTotalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Total"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/tvTotalLabel"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#202020"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPay"
            android:layout_width="128dp"
            android:layout_height="44dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Pay"
            android:textColor="#FFFFFF"
            android:backgroundTint="#202020"
            app:cornerRadius="22dp"/>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>