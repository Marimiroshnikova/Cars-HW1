<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <!-- Header: Shop + Search + Filter -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="115dp"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/tvShopTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="18dp"
            android:layout_marginRight="20dp"
            android:text="Shop"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#202020"/>

        <LinearLayout
            android:id="@+id/searchBar"
            android:layout_width="232dp"
            android:layout_height="38dp"
            android:layout_centerHorizontal="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="18dp"
            android:orientation="horizontal"
            android:background="@drawable/search_bg"
            android:paddingStart="16dp"
            android:paddingEnd="10dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clothing"
                android:textSize="16sp"
                android:textColor="#0042E0"/>
            <ImageView
                android:layout_width="20dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_camera"/>
        </LinearLayout>

        <ImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_toEndOf="@id/searchBar"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="18dp"
            android:layout_marginStart="40dp"
            android:src="@drawable/ic_sliders"/>

    </RelativeLayout>

    <!-- Gap -->
    <View
        android:layout_width="match_parent"
        android:layout_height="50dp"/>

    <!-- Grid -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="28dp"
                android:baselineAligned="false">

                <!-- Car 1 -->
                <LinearLayout
                    android:id="@+id/car1Layout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/car1"
                            android:scaleType="centerCrop"/>
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="BMW M3 (F80 generation)"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:maxLines="2"
                        android:paddingTop="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="$38,000"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#202020"
                        android:maxLines="1"
                        android:ellipsize="none"
                        android:paddingTop="4dp"/>
                </LinearLayout>

                <!-- Car 2 -->
                <LinearLayout
                    android:id="@+id/car2Layout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/car2"
                            android:scaleType="centerCrop"/>
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Mercedes-Benz CLA-Class (Second Generation)"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:maxLines="2"
                        android:paddingTop="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="$46,400"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#202020"
                        android:maxLines="1"
                        android:ellipsize="none"
                        android:paddingTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Car 3 -->
                <LinearLayout
                    android:id="@+id/car3Layout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/car3"
                            android:scaleType="centerCrop"/>
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Porsche 911 GT3 RS (991.1 Generation)"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:maxLines="2"
                        android:paddingTop="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="$189,000"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#202020"
                        android:maxLines="1"
                        android:ellipsize="none"
                        android:paddingTop="4dp"/>
                </LinearLayout>

                <!-- Car 4 -->
                <LinearLayout
                    android:id="@+id/car4Layout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/car4"
                            android:scaleType="centerCrop"/>
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Ferrari 488 Spider"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:maxLines="2"
                        android:paddingTop="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="$260,000"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#202020"
                        android:maxLines="1"
                        android:ellipsize="none"
                        android:paddingTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>